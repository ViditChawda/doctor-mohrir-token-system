rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Tokens collection - allow public read and write for booking system
    match /tokens/{tokenId} {
      // Allow anyone to read tokens
      allow read: if true;
      
      // Allow anyone to create tokens
      allow create: if true;
      
      // Allow anyone to delete tokens (for clearing old tokens)
      allow delete: if true;
      
      // Allow updates (in case needed in future)
      allow update: if true;
    }
    
    // Deny all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

